# ── GitHub App (for webhooks + repo access) ──────────────────────────────
# Create at: https://github.com/settings/apps/new
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY\n-----END RSA PRIVATE KEY-----
GITHUB_WEBHOOK_SECRET=your_random_webhook_secret

# ── GitHub OAuth App (for website login) ─────────────────────────────────
# Use same GitHub App's Client ID/Secret (shown on your GitHub App settings page)
# OR create a separate OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_oauth_client_id
GITHUB_CLIENT_SECRET=your_oauth_client_secret

# ── Gemini AI (free at aistudio.google.com/app/apikey) ───────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── JWT secret (any random string) ───────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string

# ── URLs ──────────────────────────────────────────────────────────────────
# Local dev
FRONTEND_URL=http://localhost:5173
# Production (comma-separated if multiple)
# FRONTEND_URL=https://pipeline-autopilot.vercel.app

# ── Database ──────────────────────────────────────────────────────────────
# Local: SQLite (leave as-is)
DATABASE_URL=sqlite+aiosqlite:///./pipeline_autopilot.db
# Production: Railway sets this automatically
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
