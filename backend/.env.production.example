# ── Set these in Railway's environment variables panel ──────────────────────

# GitHub OAuth (update callback URL to your Railway backend URL)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# AI provider
# Preferred for hackathon APIM / Azure OpenAI gateway
AZURE_OPENAI_ENDPOINT=https://your-apim.azure-api.net
AZURE_OPENAI_API_KEY=your_team_key
AZURE_OPENAI_DEPLOYMENT=gpt-5-chat
AZURE_OPENAI_API_VERSION=your_api_version

# Optional direct OpenAI Platform fallback
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5

# Optional legacy providers
GEMINI_API_KEY=your_gemini_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-4o

# JWT — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_random_32char_secret

# Railway auto-provides DATABASE_URL when you add a PostgreSQL plugin
# It will look like: postgresql://user:pass@host:port/dbname
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Your Vercel frontend URL (set after deploying frontend)
FRONTEND_URL=https://your-app.vercel.app
